{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/scripts/session-start.sh\"",
            "timeout": 3
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/scripts/prompt-submit.sh\"",
            "timeout": 2
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/scripts/pre-tool-use.sh\"",
            "timeout": 2
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "prompt",
            "model": "claude-haiku-4-5-20251001",
            "prompt": "You are a reward-hacking detector. The model is about to edit a file. The hook input contains tool_input.file_path and tool_input.new_string (or tool_input.content). If the file path matches a test/spec pattern (anything containing 'test', 'spec', '__tests__', 'fixtures'), examine the change. Return {\"ok\": false, \"reason\": \"...\"} ONLY if the edit appears to weaken an assertion, change an expected value to match observed (broken) output, delete a failing test case, or add a skip/xfail marker without justification. Return {\"ok\": true} for legitimate test changes (refactor, new behavior under test, fixture updates, formatting). For non-test files, always return {\"ok\": true}. Be precise — false positives are costly. Only block on clear reward-hacking patterns."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/scripts/post-tool-use.sh\"",
            "timeout": 2
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/scripts/post-tool-use-failure.sh\"",
            "timeout": 2
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/scripts/pre-compact.sh\"",
            "timeout": 2
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/scripts/post-compact.sh\"",
            "timeout": 2
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/scripts/subagent-start.sh\"",
            "timeout": 2
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/scripts/subagent-stop.sh\"",
            "timeout": 2
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/scripts/task-completed.sh\"",
            "timeout": 2
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/scripts/stop.sh\"",
            "timeout": 2
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/scripts/stop-integrity-async.sh\"",
            "asyncRewake": true,
            "rewakeMessage": "[functional-emotions stop-integrity reviewer — same LLM check (Haiku via curl) the previous agent-type hook did, plus heuristic backstop, now routed async so Stop does not block. Same safeguard, faster path.]",
            "rewakeSummary": "Stop-integrity reviewer flagged reward-hack pattern(s)",
            "timeout": 90
          }
        ]
      }
    ]
  }
}
